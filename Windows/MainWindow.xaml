<Window x:Class="XCapture.Windows.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="XCapture"
        Width="900"
        Height="620"
        MinWidth="720"
        MinHeight="480"
        Background="#F3F4F6"
        Closing="Window_Closing">
    <Window.Resources>
        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="42"/>
            <Setter Property="MinWidth" Value="132"/>
            <Setter Property="Padding" Value="18,0"/>
            <Setter Property="Margin" Value="0,0,10,0"/>
            <Setter Property="Background" Value="#2563EB"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#1D4ED8"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style x:Key="SecondaryButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="Foreground" Value="#111827"/>
            <Setter Property="BorderBrush" Value="#D1D5DB"/>
        </Style>
    </Window.Resources>

    <DockPanel>
        <Border DockPanel.Dock="Top"
                Background="#FFFFFF"
                BorderBrush="#D1D5DB"
                BorderThickness="0,0,0,1"
                Padding="18">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="XCapture"
                               FontSize="22"
                               FontWeight="Bold"
                               Foreground="#111827"/>
                    <TextBlock Text="Ctrl+Shift+S 영역 캡쳐, Ctrl+Shift+A 전체 화면 캡쳐"
                               Margin="0,4,0,0"
                               Foreground="#6B7280"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="영역 캡쳐" Click="RegionCaptureButton_Click" Style="{StaticResource PrimaryButtonStyle}"/>
                    <Button Content="전체 화면" Click="FullScreenCaptureButton_Click" Style="{StaticResource SecondaryButtonStyle}"/>
                    <Button Content="새로고침" Click="RefreshButton_Click" Style="{StaticResource SecondaryButtonStyle}"/>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Margin="18">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock Text="최근 캡쳐 10개"
                       FontSize="17"
                       FontWeight="SemiBold"
                       Foreground="#111827"
                       Margin="0,0,0,12"/>

            <ListBox x:Name="HistoryList"
                     Grid.Row="1"
                     ItemsSource="{Binding HistoryItems}"
                     MouseDoubleClick="HistoryList_MouseDoubleClick"
                     BorderBrush="#D1D5DB"
                     Background="#FFFFFF"
                     Padding="8">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border Padding="10"
                                Margin="0,0,0,8"
                                BorderBrush="#E5E7EB"
                                BorderThickness="1"
                                Background="#FFFFFF">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="128"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Border Width="112"
                                        Height="72"
                                        BorderBrush="#E5E7EB"
                                        BorderThickness="1"
                                        Background="#F9FAFB">
                                    <Image Source="{Binding Thumbnail}"
                                           Stretch="Uniform"/>
                                </Border>
                                <StackPanel Grid.Column="1"
                                            Margin="14,0"
                                            VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Title}"
                                               FontWeight="SemiBold"
                                               Foreground="#111827"/>
                                    <TextBlock Text="{Binding CreatedText}"
                                               Margin="0,4,0,0"
                                               Foreground="#6B7280"/>
                                </StackPanel>
                                <Button Grid.Column="2"
                                        Content="열기"
                                        MinWidth="72"
                                        Height="32"
                                        Click="OpenHistoryButton_Click"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Grid>
    </DockPanel>
</Window>
