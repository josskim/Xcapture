<Window x:Class="XCapture.Windows.PrintPreviewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="인쇄 미리보기"
        Width="920"
        Height="680"
        MinWidth="760"
        MinHeight="520"
        Background="#F3F4F6"
        WindowStartupLocation="CenterOwner">
    <Window.Resources>
        <Style x:Key="PanelLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#374151"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>
        <Style x:Key="SelectStyle" TargetType="ComboBox">
            <Setter Property="Height" Value="36"/>
            <Setter Property="Margin" Value="0,0,0,18"/>
            <Setter Property="Padding" Value="8,0"/>
        </Style>
        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="38"/>
            <Setter Property="MinWidth" Value="92"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#D1D5DB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="#111827"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style x:Key="PrimaryButtonStyle" TargetType="Button" BasedOn="{StaticResource ActionButtonStyle}">
            <Setter Property="Background" Value="#F59E0B"/>
            <Setter Property="BorderBrush" Value="#D97706"/>
            <Setter Property="Foreground" Value="#111827"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                Background="#FFFFFF"
                BorderBrush="#D1D5DB"
                BorderThickness="0,0,1,0"
                Padding="22">
            <DockPanel>
                <StackPanel DockPanel.Dock="Top">
                    <TextBlock Text="인쇄 설정"
                               FontSize="20"
                               FontWeight="Bold"
                               Foreground="#111827"
                               Margin="0,0,0,24"/>

                    <TextBlock Text="인쇄 방향" Style="{StaticResource PanelLabelStyle}"/>
                    <ComboBox x:Name="OrientationBox"
                              Style="{StaticResource SelectStyle}"
                              SelectionChanged="PrintOption_Changed">
                        <ComboBoxItem Content="세로" Tag="Portrait" IsSelected="True"/>
                        <ComboBoxItem Content="가로" Tag="Landscape"/>
                    </ComboBox>

                    <TextBlock Text="용지 크기" Style="{StaticResource PanelLabelStyle}"/>
                    <ComboBox x:Name="PaperSizeBox"
                              Style="{StaticResource SelectStyle}"
                              SelectionChanged="PrintOption_Changed">
                        <ComboBoxItem Content="A4 (210 x 297mm)" Tag="A4" IsSelected="True"/>
                        <ComboBoxItem Content="Letter (8.5 x 11in)" Tag="Letter"/>
                    </ComboBox>

                    <TextBlock Text="크기 조정" Style="{StaticResource PanelLabelStyle}"/>
                    <ComboBox x:Name="ScaleBox"
                              Style="{StaticResource SelectStyle}"
                              SelectionChanged="PrintOption_Changed">
                        <ComboBoxItem Content="페이지에 맞추기" Tag="Fit" IsSelected="True"/>
                        <ComboBoxItem Content="원본 크기" Tag="Actual"/>
                    </ComboBox>

                    <TextBlock Text="미리보기는 선택한 용지와 방향 기준으로 표시됩니다."
                               TextWrapping="Wrap"
                               Foreground="#6B7280"
                               FontSize="12"
                               LineHeight="18"
                               Margin="0,8,0,0"/>
                </StackPanel>

                <StackPanel DockPanel.Dock="Bottom"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            Margin="0,24,0,0">
                    <Button Content="인쇄"
                            Click="PrintButton_Click"
                            Style="{StaticResource PrimaryButtonStyle}"/>
                    <Button Content="취소"
                            Click="CancelButton_Click"
                            Style="{StaticResource ActionButtonStyle}"
                            Margin="0"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <Grid Grid.Column="1" Background="#CBD5E1">
            <Grid.RowDefinitions>
                <RowDefinition Height="42"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Background="#E5E7EB"
                    BorderBrush="#D1D5DB"
                    BorderThickness="0,0,0,1">
                <TextBlock x:Name="PreviewInfoText"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           FontWeight="SemiBold"
                           Foreground="#374151"/>
            </Border>

            <ScrollViewer Grid.Row="1"
                          HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Auto"
                          Padding="28">
                <Grid HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Border x:Name="PaperBorder"
                            Background="White"
                            BorderBrush="#111827"
                            BorderThickness="1"
                            SnapsToDevicePixels="True">
                        <Grid x:Name="PaperContent"
                              ClipToBounds="True">
                            <Image x:Name="PreviewImage"
                                   Stretch="Uniform"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   SnapsToDevicePixels="True"
                                   RenderOptions.BitmapScalingMode="HighQuality"/>
                        </Grid>
                    </Border>
                </Grid>
            </ScrollViewer>
        </Grid>
    </Grid>
</Window>
