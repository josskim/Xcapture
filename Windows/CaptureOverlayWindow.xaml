<Window x:Class="XCapture.Windows.CaptureOverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="True"
        AllowsTransparency="True"
        Focusable="True"
        Background="#66000000"
        Cursor="Cross"
        PreviewKeyDown="Window_PreviewKeyDown"
        MouseDown="Window_MouseDown"
        MouseMove="Window_MouseMove"
        MouseUp="Window_MouseUp">
    <Canvas x:Name="RootCanvas">
        <Border Canvas.Left="24"
                Canvas.Top="22"
                Background="#DD111827"
                CornerRadius="6"
                Padding="14,9">
            <TextBlock Foreground="White"
                       FontSize="15"
                       FontWeight="SemiBold"
                       Text="드래그해서 캡쳐할 영역을 선택하세요. Esc를 누르면 취소됩니다."/>
        </Border>
        <Rectangle x:Name="SelectionRect"
                   Visibility="Collapsed"
                   Stroke="#60A5FA"
                   StrokeThickness="2"
                   Fill="#22FFFFFF"/>
    </Canvas>
</Window>
