<Window x:Class="XCapture.Windows.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="XCapture 설정"
        Width="440"
        Height="300"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="#F3F4F6">
    <Window.Resources>
        <Style x:Key="HotKeyBoxStyle" TargetType="TextBox">
            <Setter Property="Height" Value="40"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#CBD5E1"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="IsReadOnly" Value="True"/>
        </Style>
    </Window.Resources>

    <Grid Margin="22">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="캡쳐 단축키"
                   FontSize="20"
                   FontWeight="Bold"
                   Foreground="#111827"/>
        <TextBlock Grid.Row="1"
                   Text="입력칸을 선택한 뒤 사용할 키 조합을 누르세요."
                   Margin="0,5,0,18"
                   Foreground="#64748B"/>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="130"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="12"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Text="영역 캡쳐"
                       VerticalAlignment="Center"
                       FontWeight="SemiBold"
                       Foreground="#334155"/>
            <TextBox x:Name="RegionHotKeyBox"
                     Grid.Column="1"
                     Style="{StaticResource HotKeyBoxStyle}"
                     PreviewKeyDown="HotKeyBox_PreviewKeyDown"/>

            <TextBlock Grid.Row="2"
                       Text="전체화면 캡쳐"
                       VerticalAlignment="Center"
                       FontWeight="SemiBold"
                       Foreground="#334155"/>
            <TextBox x:Name="FullScreenHotKeyBox"
                     Grid.Row="2"
                     Grid.Column="1"
                     Style="{StaticResource HotKeyBoxStyle}"
                     PreviewKeyDown="HotKeyBox_PreviewKeyDown"/>
        </Grid>

        <StackPanel Grid.Row="4"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button Content="기본값"
                    Width="82"
                    Height="36"
                    Margin="0,0,8,0"
                    Click="ResetButton_Click"/>
            <Button Content="취소"
                    Width="72"
                    Height="36"
                    Margin="0,0,8,0"
                    Click="CancelButton_Click"/>
            <Button Content="저장"
                    Width="82"
                    Height="36"
                    Background="#2563EB"
                    Foreground="White"
                    BorderBrush="#1D4ED8"
                    FontWeight="SemiBold"
                    Click="SaveButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
