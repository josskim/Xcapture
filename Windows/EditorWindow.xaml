<Window x:Class="XCapture.Windows.EditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="XCapture"
        MinWidth="720"
        MinHeight="420"
        Width="1040"
        Height="720"
        Background="#F3F4F6"
        KeyDown="Window_KeyDown">
    <Window.Resources>
        <Style x:Key="TopButtonStyle" TargetType="Button">
            <Setter Property="MinWidth" Value="72"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#D1D5DB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="#111827"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
    </Window.Resources>

    <DockPanel>
        <Border DockPanel.Dock="Top"
                Background="#FFFFFF"
                BorderBrush="#D1D5DB"
                BorderThickness="0,0,0,1"
                Padding="12">
            <WrapPanel VerticalAlignment="Center">
                <Button x:Name="PenButton" Content="펜" Click="PenButton_Click" Style="{StaticResource TopButtonStyle}"/>
                <Button x:Name="EraserButton" Content="지우개" Click="EraserButton_Click" Style="{StaticResource TopButtonStyle}"/>

                <Border Width="1" Height="28" Background="#E5E7EB" Margin="2,0,10,0"/>

                <TextBlock Text="색상" VerticalAlignment="Center" Margin="0,0,6,0" FontWeight="SemiBold"/>
                <ComboBox x:Name="ColorBox" Width="92" Height="34" Margin="0,0,12,0" SelectionChanged="ColorBox_SelectionChanged">
                    <ComboBoxItem Content="빨강" Tag="#EF4444" IsSelected="True"/>
                    <ComboBoxItem Content="파랑" Tag="#2563EB"/>
                    <ComboBoxItem Content="검정" Tag="#111827"/>
                    <ComboBoxItem Content="노랑" Tag="#FACC15"/>
                </ComboBox>

                <TextBlock Text="굵기" VerticalAlignment="Center" Margin="0,0,6,0" FontWeight="SemiBold"/>
                <Slider x:Name="StrokeSlider" Width="110" Minimum="2" Maximum="18" Value="4" Margin="0,0,14,0" ValueChanged="StrokeSlider_ValueChanged"/>

                <Border Width="1" Height="28" Background="#E5E7EB" Margin="2,0,10,0"/>

                <Button Content="복사" Click="CopyButton_Click" Style="{StaticResource TopButtonStyle}"/>
                <Button Content="저장" Click="SaveButton_Click" Style="{StaticResource TopButtonStyle}"/>
                <Button Content="프린트" Click="PrintButton_Click" Style="{StaticResource TopButtonStyle}"/>
                <Button Content="되돌리기" Click="UndoButton_Click" Style="{StaticResource TopButtonStyle}"/>
                <Button Content="초기화" Click="ClearButton_Click" Style="{StaticResource TopButtonStyle}"/>
            </WrapPanel>
        </Border>

        <ScrollViewer HorizontalScrollBarVisibility="Auto"
                      VerticalScrollBarVisibility="Auto"
                      Background="#D1D5DB">
            <Grid x:Name="CaptureSurface"
                  Margin="24"
                  HorizontalAlignment="Center"
                  VerticalAlignment="Center">
                <Image x:Name="CaptureImage" Stretch="None"/>
                <InkCanvas x:Name="InkLayer" Background="Transparent"/>
            </Grid>
        </ScrollViewer>
    </DockPanel>
</Window>
